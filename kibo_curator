function calcScore(p) {
  const flat = [A[1], ...(A[2]||[]), ...(A[3]||[]), A[4], A[5]].filter(Boolean);
  return Math.min(p.score.filter(f => flat.includes(f)).length * 20, 95);
}

function sel(el) {
  const s = el.dataset.step;
  document.querySelectorAll('[data-step="'+s+'"]').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  A[s] = el.dataset.val;
}
function multi(el) {
  el.classList.toggle('selected');
  A[el.dataset.step] = Array.from(document.querySelectorAll('[data-step="'+el.dataset.step+'"].selected')).map(o => o.dataset.val);
}
function showStep(n) {
  document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
  const el = document.getElementById('s'+n) || document.getElementById('s-'+n);
  if (el) el.classList.add('active');
  const pct = isNaN(n) ? 100 : (n-1)/5*100;
  document.getElementById('prog').style.width = pct+'%';
  window.scrollTo(0,0);
}
function next(cur) {
  if ([1,4,5].includes(cur) && !A[cur]) { alert('항목을 선택해주세요'); return; }
  showStep(cur+1);
}
function prev(cur) { showStep(cur-1); }
function restart() {
  [1,2,3,4,5].forEach(k => { A[k] = [2,3].includes(k) ? [] : null; });
  document.querySelectorAll('.opt').forEach(o => o.classList.remove('selected'));
  showStep(1);
}
function toggleDetail(id) {
  const d = document.getElementById('detail-'+id);
  const btn = document.getElementById('tbtn-'+id);
  const icon = document.getElementById('ticon-'+id);
  const isOpen = d.classList.contains('open');
  d.classList.toggle('open');
  icon.classList.toggle('open');
  btn.querySelector('span').textContent = isOpen ? '자격조건 상세 보기 ▼' : '접기 ▲';
}
function analyze() {
  if (!A[5]) { alert('매출 규모를 선택해주세요'); return; }
  showStep('loading');
  const msgs = ['기보 보증 상품 매칭 중...','적합도 분석 중...','추천 결과 생성 중...'];
  let i = 0;
  const iv = setInterval(() => { if(i<msgs.length) document.getElementById('loading-msg').textContent = msgs[i++]; }, 700);
  setTimeout(() => {
    clearInterval(iv);
    const scored = PROGRAMS.map(p => ({...p, ms: calcScore(p)})).sort((a,b) => b.ms-a.ms);
    const results = scored.filter(p => p.ms > 0).length > 0 ? scored.filter(p => p.ms > 0) : scored.slice(0,3).map(p => ({...p, ms:30}));
    const flat = [A[1], ...(A[2]||[]), ...(A[3]||[]), A[4], A[5]].filter(Boolean);
    let txt = `<strong>${A[1]}</strong> 단계 기업으로, <strong>${A[4]}</strong> 목적의 자금을 탐색하고 있으시네요. 총 <strong>${results.length}개</strong>의 프로그램을 추천드립니다. 특히 <strong>${results[0].name}</strong>이 가장 적합합니다.`;
    document.getElementById('ai-summary').innerHTML = '<p class="ai-label">AI 분석 요약</p><p class="ai-text">'+txt+'</p>';
    document.getElementById('results-container').innerHTML = results.map((p,i) => buildCard(p,i)).join('');
    showStep('result');
  }, 2200);
}
function buildCard(p, idx) {
