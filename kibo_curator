  const id = 'c'+idx;
  return `
<div class="result-card${idx===0?' top':''}">
  <div class="card-header">
    <div class="card-top-row">
      <div><div class="card-name">${p.name}</div><div class="card-sub">${p.subtitle}</div></div>
      <span class="badge ${badgeCls}">${badgeTxt}</span>
    </div>
    <div class="score-row">
      <div class="score-bg"><div class="score-fill" style="width:${p.ms}%"></div></div>
      <span class="score-pct">적합도 ${p.ms}%</span>
    </div>
    <div class="card-amount">${p.amount}</div>
    <div class="card-desc">${p.desc}</div>
    <div class="tags">${p.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
  </div>
  <div class="card-meta">
    <div class="meta-box"><div class="meta-label">보증료</div><div class="meta-val">${p.fee}</div></div>
    <div class="meta-box"><div class="meta-label">보증 기간</div><div class="meta-val">${p.period}</div></div>
  </div>
  <button class="toggle-btn" id="tbtn-${id}" onclick="toggleDetail('${id}')">
    <span>자격조건 상세 보기 ▼</span>
  </button>
  <div class="detail" id="detail-${id}">
    <div class="detail-section">
      <p class="detail-title green">■ 필수 자격요건</p>
      <ul class="detail-list dot-green">${p.required.map(r=>`<li>${r}</li>`).join('')}</ul>
    </div>
    <div class="detail-section">
      <p class="detail-title amber">■ 우대 조건</p>
      <ul class="detail-list dot-amber">${p.preferred.map(r=>`<li>${r}</li>`).join('')}</ul>
    </div>
    <div class="detail-section">
      <p class="detail-title red">■ 지원 제외 대상</p>
      <ul class="detail-list dot-red">${p.excluded.map(r=>`<li>${r}</li>`).join('')}</ul>
    </div>
    <div class="detail-section">
      <p class="detail-title blue">■ 신청 절차</p>
      ${p.process.map((s,i)=>`<div class="proc-step"><div class="proc-num">${i+1}</div><div class="proc-text">${s}</div></div>`).join('')}
    </div>
  </div>
</div>`;
